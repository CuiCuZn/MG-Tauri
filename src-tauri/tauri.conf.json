{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FloatingBall",
  "version": "0.1.0",
  "identifier": "com.floating.ball",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "floating-ball",
        "title": "FloatingBall",
        "width": 320,
        "height": 40,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "url": "index.html"
      },
      {
        "label": "content",
        "title": "百度搜索",
        "width": 800,
        "height": 600,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "center": true,
        "url": "https://www.baidu.com"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
